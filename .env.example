# Antigravity Homelab Universe Environment Variables

# Security
API_KEY=super_secret_homelab_key

# AI Vision Tagging
GEMINI_API_KEY=your_gemini_api_key_here

# Storage Paths
# Use C:\path\to\nas for Windows testing, or /mnt/nas_data for Linux/Mac Mini
NAS_BASE_PATH=/mnt/nas_data

# Networking
KONG_GATEWAY_URL=http://127.0.0.1:8000

# Logging
LOG_LEVEL=INFO
